---
const textContent = "DISHA '26";
---

<footer class="w-full bg-black pt-12 pb-6 flex flex-col items-center justify-center overflow-hidden">
  <div class="w-full max-w-5xl px-4">
    <a href="https://www.instagram.com/dishacet" target="_blank" rel="noopener noreferrer" class="block w-full">
      <svg viewBox="0 0 800 180" class="w-full h-auto overflow-visible cursor-pointer">
        <defs>
          <mask id="textMask">
            <text x="50%" y="50%" text-anchor="middle" dominant-baseline="middle" class="font-black uppercase tracking-tighter md:tracking-normal font-display" fill="white" style="font-size:120px">
              {textContent}
            </text>
          </mask>
        </defs>

        <text x="50%" y="50%" text-anchor="middle" dominant-baseline="middle" class="font-black uppercase tracking-tighter md:tracking-normal font-display" fill="#1a102e" style="font-size:120px">
          {textContent}
        </text>

        <g mask="url(#textMask)">
          <g class="wave-group" id="footer-wave-group">
            <path class="wave-path-1" fill="#a855f7" opacity="0.4" d="M0,48 Q100,28 200,48 T400,48 T600,48 T800,48 T1000,48 T1200,48 T1400,48 T1600,48 V200 H0 Z" />
            <path class="wave-path-2" fill="#9333ea" d="M0,53 Q50,38 100,53 T200,53 T300,53 T400,53 T500,53 T600,53 T700,53 T800,53 T900,53 T1000,53 T1100,53 T1200,53 T1300,53 T1400,53 T1500,53 T1600,53 V200 H0 Z" />
          </g>
        </g>
      </svg>
    </a>
  </div>

  <div class="mt-8 flex flex-col items-center gap-4">
    <div class="h-px w-24 bg-gradient-to-r from-transparent via-purple-900/50 to-transparent" />
    <div class="flex items-center gap-6">
      <a href="https://www.instagram.com/cet.college.union" target="_blank" rel="noopener noreferrer" class="text-zinc-800 hover:text-purple-500 transition-colors text-[10px] tracking-[0.3em] font-bold uppercase">
        © 2026 CET College Union
      </a>
    </div>
  </div>
</footer>

<style>
  @keyframes waveSlide1 {
    0% { transform: translateX(-800px); }
    100% { transform: translateX(0); }
  }
  @keyframes waveSlide2 {
    0% { transform: translateX(-800px); }
    100% { transform: translateX(0); }
  }
  @keyframes waveGroupSlideUp {
    0% { transform: translateY(120px); }
    100% { transform: translateY(0); }
  }
  .wave-path-1 {
    animation: waveSlide1 8s linear infinite;
    will-change: transform;
  }
  .wave-path-2 {
    animation: waveSlide2 5s linear infinite;
    transform: translateY(35px);
    will-change: transform;
  }
  .wave-group {
    transform: translateY(120px);
    opacity: 0;
    transition: transform 4s cubic-bezier(0, 0, 0.2, 1), opacity 0.5s ease;
  }
  .wave-group.visible {
    transform: translateY(0);
    opacity: 1;
  }
</style>

<script>
  const waveGroup = document.getElementById('footer-wave-group');
  if (waveGroup) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          waveGroup.classList.add('visible');
          observer.unobserve(waveGroup);
        }
      },
      { threshold: 0.1 }
    );
    observer.observe(waveGroup);
  }
</script>
