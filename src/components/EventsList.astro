---
import DitherCanvas from './ThreeCanvasImpl.jsx';
const FINISHED_NORMALIZED = new Set([
  'biathlon', 'tug of war', 'cycle slow race', 'super over (w)',
  'cricket', 'film review', 'mx-techie', 'bottle art',
  'calligraphy', 'clay modelling', 'origami', 'oil painting',
  'pencil drawing', 'doodle art', 'dumb charades', 'mimicry',
  'light music', 'spot commentary', 'ideathon', 'mono act',
  'cartoon', 'open debate', "rubik's cube", 'western (duet)',
  'guess who?', 'channel surfing', 'digital painting', 'minimal poster',
  'speed typing', 'water colouring', 'face painting',
  'department magazine', 'treasure hunt', 'integration bee', 'quiz',
  'prompt writing', 'story writing', 'caption writing',
  'jam (english)', 'jam (malayalam)',
  'versification', 'recitation',
]);

function isFinished(item) {
  const norm = item.toLowerCase().trim();
  if (FINISHED_NORMALIZED.has(norm)) return true;
  const base = norm.replace(/\((?:eng|mal|hin|english|malayalam|m\/w|w|m)\)/gi, '').trim();
  if (FINISHED_NORMALIZED.has(base)) return true;
  return false;
}

const REAL_EVENTS_DATA = [
  { id: 1, title: 'MAIN EVENTS', eventsList: ['RJ Hunt','Face of Disha', 'MX-Techie', 'MX-Disha', 'Fashion Show', 'Street Play', 'Disha Idol', 'Just Dance', 'Wall Painting'] },
  { id: 2, title: 'TECHNICAL', eventsList: ['Ideathon', 'Quiz', 'Technical Essay', 'Prompt Writing', 'Speed Typing'] },
  { id: 3, title: 'E-GAMES', eventsList: ['E-Football', 'BGMI', 'Valorant', 'Mini Militia', 'Free Fire', 'FIFA', 'COD'] },
  { id: 4, title: 'SPORTS', eventsList: ['Football', 'Cricket', 'Volleyball', 'Tug of War', 'Badminton', 'Table Tennis', 'Chess', 'Carroms', 'Cycle Slow Race', 'Basketball', 'Arm Wrestling', 'Super Over (W)', 'Penalty Shoot (W)', 'Mr. Ponjikkara'] },
  { id: 5, title: 'ATHLETICS', eventsList: ['100M Race (M/W)', 'Shot Put (M/W)', 'High Jump', 'Long Jump', '400 M Relay (M/W)', 'Brisk Walk 800M (M/W)', '200M Race (M/W)', 'Biathlon'] },
  { id: 6, title: 'LITERARY', eventsList: ['Essay Writing (Eng)', 'Essay Writing (Mal)', 'Essay Writing (Hin)', 'Versification (Eng)', 'Versification (Mal)', 'Versification (Hin)', 'Jingle Writing (Eng)', 'Jingle Writing (Mal)', 'Book Review', 'Film Review', 'Recitation (Eng)', 'Recitation (Mal)', 'Recitation (Hin)', 'Story Writing (Eng)', 'Story Writing (Mal)','Story Writing (Hin)' ,'Caption Writing (Eng)', 'Caption Writing (Mal)', 'Extempore (Eng)', 'Extempore (Mal)', 'Extempore (Hin)'] },
  { id: 7, title: 'MUSICAL', eventsList: ['Classical Music', 'Light Music', 'Western (Duet)', 'Bands Battle', 'Nadanpattu', 'Unplugged', 'Mappilappattu'] },
  { id: 8, title: 'DANCE', eventsList: ['Adapt Tunes', 'Prepared Duo', 'Prepared Solo'] },
  { id: 9, title: 'THEATRICAL', eventsList: ['Street Play', 'Mono Act', 'Mimicry', 'Stand-up Comedy', 'Skit'] },
  { id: 10, title: 'ART', eventsList: ['Pencil Drawing', 'Water Colouring', 'Cartoon', 'Digital Painting', 'Face Painting', 'Doodle Art', 'Minimal Poster', 'Oil Painting', 'Clay Modelling', 'Origami', 'Bottle Art', 'Calligraphy'] },
  { id: 11, title: 'MISC', eventsList: ['Troll Making', 'Rubik\'s Cube', 'Short Film','Dumb Charades', 'Department Magazine', 'Mannequin', 'Trailer Making', 'Reel Making', 'Business (Naaptol)', 'Channel Surfing', 'Guess Who?', 'Treasure Hunt', 'Open Debate', 'Jam (English)','Jam (Malayalam)', 'Integration Bee', 'Spot Commentary', 'Shot Story', 'Picture Perception', 'Theme-Based Photography', 'Movie Recreation'] },
];
---
<section id="events" class="relative w-full bg-black z-20" style="touch-action: pan-y;">
  <div class="absolute inset-0 z-0 h-full w-full pointer-events-auto">
    <div class="sticky top-0 w-full h-[100dvh] overflow-hidden bg-black">
      <div class="absolute inset-0 w-full h-full">
        <DitherCanvas
          client:load
          waveColor={[0.45, 0.0, 0.2]}
          disableAnimation={false}
          enableMouseInteraction={true}
          mouseRadius={0.6}
          colorNum={4}
          waveAmplitude={0.3}
          waveFrequency={3}
          waveSpeed={0.05}
        />
      </div>
      <div class="absolute inset-0 bg-black/30 pointer-events-none"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-[#8A003B]/30 via-transparent to-transparent opacity-80 pointer-events-none"></div>
      <div class="absolute top-0 left-0 w-full h-64 md:h-96 bg-gradient-to-b from-black via-black/60 to-transparent z-10 pointer-events-none"></div>
    </div>
  </div>
  <div id="events-scroll-section" class="sticky top-0 z-10 w-full h-[100dvh] flex items-center overflow-hidden pointer-events-none">
    <div class="absolute top-10 md:top-14 left-0 z-50 w-full flex justify-center pointer-events-none px-4">
      <h2 class="flex flex-col md:flex-row items-center md:items-baseline gap-1 md:gap-5">
        <span class="text-[#DE005F] -mt-4 font-['Sedgwick_Ave_Display',_cursive] font-extrabold tracking-[-0.05em] text-6xl md:text-9xl relative [text-shadow:0_0_15px_#DE005F]">
          EVENTS
        </span>
      </h2>
    </div>
    <div id="events-cards-wrapper" class="flex items-center h-full w-max px-[5vw] gap-6 md:gap-12 mt-28 md:mt-32">
      {REAL_EVENTS_DATA.map((event) => (
        <div
          key={event.id}
          class="event-card pointer-events-auto w-[85vw] sm:w-[60vw] md:w-[45vw] lg:w-[32vw] h-[70vh] flex flex-col bg-black/60 border border-white/10 rounded-none p-6 md:p-10 shrink-0 shadow-none md:shadow-[0_0_50px_rgba(0,0,0,0.5)] relative overflow-hidden"
        >
          <div class="shrink-0 mb-6 w-full flex justify-center">
            <h3 class="text-2xl sm:text-3xl md:text-4xl font-black uppercase tracking-wider text-[#DE005F] break-words text-center font-bohme [text-shadow:0_0_15px_#DE005F]">
              {event.title}
            </h3>
          </div>
          <div class="flex-grow overflow-y-auto md:overflow-y-scroll overflow-x-hidden custom-scrollbar pr-2 relative w-full">
            <div class="relative flex items-center justify-center gap-3 mb-6 sticky top-0 z-20 pt-2 pb-6 -mt-2 w-full">
            <div class="absolute inset-0 bg-gradient-to-b from-black/90 via-black/50 to-transparent pointer-events-none"></div>
              <span class="relative z-10 h-px flex-grow bg-gradient-to-r from-transparent to-[#DE005F]"></span>
              <span class="relative z-10 h-px flex-grow bg-gradient-to-l from-transparent to-[#DE005F]/50"></span>
            </div>
            <div class="flex flex-col w-full">
              {event.eventsList.map((item, index) => (
                <div key={index} class="group flex items-start gap-4 py-3 md:py-4 border-b border-white/10 hover:border-white/30 transition-colors w-full">
                  <span class="text-[#DE005F] font-black text-sm md:text-base w-5 shrink-0 mt-0.5 font-myriad">
                    {(index + 1).toString().padStart(2, '0')}
                  </span>
                  <span class:list={["text-white/90 group-hover:text-white font-bold tracking-wide text-sm sm:text-base md:text-lg flex-1 break-words whitespace-normal leading-snug font-myriad", isFinished(item) && "line-through opacity-60 decoration-[#DE005F]"]}>
                    {item}
                  </span>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
  <div id="events-spacer" class="w-full pointer-events-none"></div>
</section>

<style>
  /* Promote wrapper to its own compositor layer once, avoid promote-3d overhead */
  #events-cards-wrapper {
    will-change: transform;
    transform: translateZ(0);
  }
</style>

<script>
(function () {
  'use strict';

  var wrapper = document.getElementById('events-cards-wrapper');
  var spacer  = document.getElementById('events-spacer');
  if (!wrapper || !spacer) return;

  var section = document.getElementById('events');
  if (!section) return;

  /* ─── state ─────────────────────────────────────────────────── */
  var sectionTop  = 0;     // px from document top — set on every (settled) layout pass
  var maxScroll   = 0;     // total horizontal travel of the wrapper
  var stretch     = 1;     // K — vertical-scroll-px per horizontal-px (>=1)
  var displayX    = 0;     // what's currently rendered
  var rafId       = null;

  /* Vertical scroll distance allocated per card, as a fraction of the
     viewport height — this is what gives each card (including the first)
     enough scroll "runway" that a single wheel/trackpad tick can't blow
     through it. Tuned, not arbitrary-feeling: 1.0 == "one viewport-height
     of scroll per card", matching the dwell time of a normal vertically
     stacked section. */
  var SCROLL_PER_CARD_VH = 0.85;

  /* gesture guards — block re-measurement mid-interaction so values never
     drift out from under an in-progress scroll/touch (this was the source
     of the "fighting" / jump bugs) */
  var gestureActive = false; // true while touch-drag or fling momentum is live
  var pendingSetup  = false; // true when a re-measure is deferred because we're mid-scroll
  var suppressingScroll = false; // true while window.scrollTo() is being called internally

  /* touch state */
  var touchActive = false;
  var touchStartX = 0;
  var touchStartY = 0;
  var touchBaseX  = 0;
  var prevTouchX  = 0;
  var prevTouchT  = 0;
  var velX        = 0; // px / ms

  /* ─── helpers ────────────────────────────────────────────────── */
  function clamp(v, lo, hi) { return v < lo ? lo : v > hi ? hi : v; }

  /* getBoundingClientRect is reliable across the sticky/absolute ancestor
     chain in this layout (offsetTop is not). Only called from setup(). */
  function getSectionTop() {
    return section.getBoundingClientRect().top + window.scrollY;
  }

  function applyTransform(x) {
    wrapper.style.transform = 'translate3d(' + (-x) + 'px,0,0)';
  }

  function insidePin() {
    var sy = window.scrollY;
    return sy >= sectionTop - 1 && sy <= sectionTop + maxScroll * stretch + 1;
  }

  /* ─── setup — recomputes geometry; never called mid-gesture ──── */
  function setup() {
    if (gestureActive || insidePin()) { pendingSetup = true; return; }
    pendingSetup = false;

    var lastCard = wrapper.lastElementChild;
    if (lastCard) {
      var lastCardRect = lastCard.getBoundingClientRect();
      var naturalRight = lastCardRect.right + displayX;
      maxScroll = Math.max(0, naturalRight - document.documentElement.clientWidth);
    } else {
      maxScroll = 0;
    }
    sectionTop = getSectionTop();

    /* Tie the stretch factor to the viewport: allocate
       (cardCount * viewportHeight * SCROLL_PER_CARD_VH) px of vertical
       scroll to traverse maxScroll px of horizontal travel. This keeps
       per-card dwell time felt-consistent across screen sizes — a wide
       monitor (more horizontal travel relative to height) gets a smaller
       stretch, a narrow/tall viewport gets a larger one.
       Clamped to >= 1 so we only ever stretch, never compress (compressing
       would reintroduce the original "card skipped" bug at 1:1). */
    var cardCount = wrapper.children.length || 1;
    var viewportH = document.documentElement.clientHeight;
    var desiredSpacerHeight = cardCount * viewportH * SCROLL_PER_CARD_VH;
    stretch = maxScroll > 0 ? Math.max(1, desiredSpacerHeight / maxScroll) : 1;

    /* No artificial lead-in. `position: sticky` already guarantees the
       card is fully visible the instant the section pins — horizontal
       motion can start immediately without skipping any content. */
    spacer.style.height = (maxScroll * stretch) + 'px';

    displayX = clamp((window.scrollY - sectionTop) / stretch, 0, maxScroll);
    applyTransform(displayX);
  }

  /* ─── RAF loop — fling momentum only ──────────────────────────── */
  var FRICTION = 0.88;

  function loop() {
    rafId = null;

    if (touchActive) return;

    if (pendingSetup && !insidePin()) { setup(); if (pendingSetup) return; }

    if (Math.abs(velX) > 0.05) {
      displayX = clamp(displayX + velX * 16.67, 0, maxScroll);
      velX *= FRICTION;
      applyTransform(displayX);
      suppressingScroll = true;
      window.scrollTo({ top: sectionTop + displayX * stretch, behavior: 'instant' });
      suppressingScroll = false;
      rafId = requestAnimationFrame(loop);
    } else {
      gestureActive = false; // momentum settled — safe to re-measure again
    }
  }

  function startLoop() {
    if (!rafId) rafId = requestAnimationFrame(loop);
  }

  /* ─── Scroll handler — read-only, batched via rAF ─────────────── */
  var scrollQueued = false;
  function onScroll() {
    if (touchActive || scrollQueued || suppressingScroll) return;
    scrollQueued = true;
    requestAnimationFrame(function () {
      scrollQueued = false;

      if (pendingSetup && !gestureActive && !insidePin()) {
        setup();
        if (pendingSetup) return;
      }

      var target = clamp((window.scrollY - sectionTop) / stretch, 0, maxScroll);
      if (target !== displayX) {
        displayX = target;
        applyTransform(displayX);
      }
    });
  }

  /* ─── Touch handlers — drive displayX directly, same coord space
         as the wheel/scroll path above (shared sectionTop/maxScroll) ─ */
  function onTouchStart(e) {
    var t = e.touches[0];
    touchStartX = t.clientX;
    touchStartY = t.clientY;
    prevTouchX  = t.clientX;
    prevTouchT  = performance.now();
    touchBaseX  = displayX;
    velX        = 0;
    touchActive = false; // axis decided on first move
    gestureActive = true;
    if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
  }

  function onTouchMove(e) {
    var t  = e.touches[0];
    var dx = touchStartX - t.clientX;
    var dy = touchStartY - t.clientY;

    if (!touchActive) {
      if (Math.abs(dx) < 4 && Math.abs(dy) < 4) return;
      if (Math.abs(dy) >= Math.abs(dx)) {
        /* vertical gesture — let the browser scroll natively; our scroll
           handler keeps displayX in sync via sectionTop/maxScroll */
        gestureActive = false;
        return;
      }
      touchActive = true;
    }

    if (e.cancelable) e.preventDefault();

    var now = performance.now();
    var dt  = now - prevTouchT;
    if (dt > 0) velX = (prevTouchX - t.clientX) / dt;
    prevTouchX = t.clientX;
    prevTouchT = now;

    displayX = clamp(touchBaseX + dx, 0, maxScroll);
    applyTransform(displayX);
  }

  function onTouchEnd() {
    if (!touchActive) { gestureActive = false; return; }
    touchActive = false;

    suppressingScroll = true;
    window.scrollTo({ top: sectionTop + displayX * stretch, behavior: 'instant' });
    suppressingScroll = false;

    if (Math.abs(velX) > 0.05) {
      velX *= 16.67;
      startLoop(); // gestureActive stays true until momentum settles
    } else {
      gestureActive = false;
    }
  }

  /* ─── Wire up ───────────────────────────────────────────────── */
  window.addEventListener('scroll', onScroll, { passive: true });

  section.addEventListener('touchstart',  onTouchStart, { passive: true });
  section.addEventListener('touchmove',   onTouchMove,  { passive: false });
  section.addEventListener('touchend',    onTouchEnd,   { passive: true });
  section.addEventListener('touchcancel', onTouchEnd,   { passive: true });

  /* Unified re-measure trigger — fires on genuine box-size changes of the
     cards wrapper (never JS-mutated, so no feedback loop) and on viewport
     resize. Both paths share the same debounced guard that defers execution
     when the user is mid-scroll through the pin region. */
  var remeasureTimer;
  function scheduleRemeasure() {
    clearTimeout(remeasureTimer);
    remeasureTimer = setTimeout(function () {
      if (gestureActive || insidePin()) { pendingSetup = true; return; }
      setup();
    }, 150);
  }

  window.addEventListener('resize', scheduleRemeasure, { passive: true });

  var ro = new ResizeObserver(scheduleRemeasure);
  ro.observe(wrapper);

  /* Run setup after layout + fonts are stable so scrollWidth is measured
     against final geometry, not a pre-reflow DOM. */
  function ready() {
    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(function () {
        requestAnimationFrame(function () { requestAnimationFrame(setup); });
      });
    } else {
      requestAnimationFrame(function () { requestAnimationFrame(setup); });
    }
  }

  if (document.readyState === 'complete') {
    ready();
  } else {
    window.addEventListener('load', ready, { once: true });
  }
})();
</script>
